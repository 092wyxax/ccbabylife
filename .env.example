# 日系選物店 — 環境變數範本
# 複製此檔為 .env.local 並填入實際值
# 切勿將 .env.local 提交至 Git

# ── Next.js ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=日系選物店

# ── Supabase ─────────────────────────────────────
# 從 Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle 直連
# Vercel serverless 走 pgbouncer transaction mode（port 6543）
DATABASE_URL=postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:6543/postgres
# drizzle-kit migration 用直連（port 5432）
DATABASE_URL_DIRECT=postgresql://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── LINE Login（前台）─────────────────────────────
# https://developers.line.biz/console/ → Provider → LINE Login channel
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# 自簽 JWT 用，建議 openssl rand -hex 32 產生
LINE_JWT_SECRET=

# ── LINE Messaging API（後台 Bot + 推播）──────────
# https://developers.line.biz/console/ → Provider → Messaging API channel
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_ACCESS_TOKEN=
LINE_OFFICIAL_ID=

# ── 綠界 ECPay ────────────────────────────────────
# 測試環境用 sandbox 帳號，正式上線需另外申請
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_RETURN_URL=https://your-domain.com/api/webhooks/ecpay
ECPAY_NOTIFY_URL=https://your-domain.com/api/webhooks/ecpay
ECPAY_ENV=stage

# ── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Cloudflare ────────────────────────────────────
CF_ACCOUNT_ID=
CF_IMAGES_TOKEN=
CF_WORKERS_TOKEN=
# R2 用於資料庫備份
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=nihon-select-backups

# ── Email（Resend，LINE 之外的通知 fallback）──────
RESEND_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# ── 監控 ──────────────────────────────────────────
SENTRY_DSN=
# 僅 build 時用，不可進 client bundle
SENTRY_AUTH_TOKEN=

# ── Turnstile（Cloudflare 人機驗證；留空時整功能停用，表單照常運作）──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── 公司資訊 ──────────────────────────────────────
COMPANY_TAX_ID=60766849
COMPANY_NAME=
